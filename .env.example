# Copy this file to ".env" to set defaults for the server.
# None of this is required to run the app — you can also just paste your
# key into Settings inside the web UI once it's running.

# Optional: a default AgentRouter API key the server falls back to if the
# browser hasn't saved one yet. Get a key from https://agentrouter.org/console/token
AGENTROUTER_API_KEY=

# Optional: change the local port the app runs on (default 3000)
PORT=3000
